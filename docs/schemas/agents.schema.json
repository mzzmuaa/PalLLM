{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://palllm.dev/schemas/agents-v1.schema.json",
  "title": "PalLLM Agent Capability Manifest",
  "description": "Formal JSON Schema 2020-12 contract for agents.json - the machine-readable agent capability manifest at the repo root. Companion to AGENTS.md (the human-readable form). Source of truth for shape: agents.json itself; this schema mirrors that shape so any caller can validate before consuming.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schemaVersion",
    "lastAudited",
    "project",
    "rollingState",
    "capabilities",
    "validationGates",
    "hardRules"
  ],
  "properties": {
    "$schema":  { "type": "string" },
    "$comment": { "type": "string" },

    "schemaVersion": {
      "type": "integer",
      "const": 1,
      "description": "Manifest schema version. Always 1 for now."
    },
    "lastAudited": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "description": "ISO date the manifest was last hand-audited. Drift-gated by the 45-day freshness cap."
    },

    "project": {
      "type": "object",
      "required": ["name", "kind", "license", "rootEntryPoints"],
      "additionalProperties": true,
      "properties": {
        "name":     { "type": "string", "minLength": 1 },
        "kind":     { "type": "string", "minLength": 1 },
        "license":  { "type": "string", "minLength": 1 },
        "scope":    { "type": "string" },
        "runtime": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "framework":          { "type": "string" },
            "host":               { "type": "string" },
            "lua":                { "type": "string" },
            "mcpProtocolVersion": { "type": "string" },
            "openApiVersion":     { "type": "string" }
          }
        },
        "rootEntryPoints": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["kind", "path", "audience"],
            "additionalProperties": false,
            "properties": {
              "kind":     { "type": "string", "minLength": 1 },
              "path":     { "type": "string", "minLength": 1 },
              "audience": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    },

    "rollingState": {
      "type": "object",
      "additionalProperties": true,
      "description": "Cross-checked counts. Bumped in lockstep with code changes via the drift gates.",
      "properties": {
        "$comment":           { "type": "string" },
        "tests":              { "type": "integer", "minimum": 0 },
        "driftGates":         { "type": "string" },
        "buildWarnings":      { "type": "integer", "minimum": 0 },
        "apiRoutes":          { "type": "integer", "minimum": 0 },
        "operationalRoutes":  { "type": "integer", "minimum": 0 },
        "mcpProtocolRoutes":  { "type": "integer", "minimum": 0 },
        "mcpTools":           { "type": "integer", "minimum": 0 },
        "mcpResources":       { "type": "integer", "minimum": 0 },
        "mcpPrompts":         { "type": "integer", "minimum": 0 },
        "fallbackStrategies": { "type": "integer", "minimum": 0 },
        "featureCatalog":     { "type": "integer", "minimum": 0 },
        "featureReady":       { "type": "integer", "minimum": 0 },
        "featureScaffolded":  { "type": "integer", "minimum": 0 },
        "featureDeferred":    { "type": "integer", "minimum": 0 },
        "adrsAccepted":       { "type": "integer", "minimum": 0 },
        "docsCount":          { "type": "integer", "minimum": 0 },
        "honestRoadmap":      { "type": "string" }
      }
    },

    "capabilities": {
      "type": "object",
      "minProperties": 1,
      "description": "Each entry is a capability an agent can exercise here. Open-ended set; named keys (e.g. verbRunner, httpSurface, mcpSurface) carry a summary + relevant paths.",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": true,
        "required": ["summary"],
        "properties": {
          "summary": { "type": "string", "minLength": 1 }
        }
      }
    },

    "validationGates": {
      "type": "object",
      "additionalProperties": true,
      "required": ["fullAuditCommand"],
      "properties": {
        "$comment":         { "type": "string" },
        "fullAuditCommand": { "type": "string", "minLength": 1 },
        "buildAndTest": {
          "type": "array",
          "items": { "$ref": "#/$defs/gate" }
        },
        "drift": {
          "type": "array",
          "items": { "$ref": "#/$defs/gate" }
        }
      }
    },

    "hardRules": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "description": "Invariants no change may violate. Each item a single sentence stating the rule + its rationale."
    },

    "antiPatterns": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "summary": { "type": "string" },
        "doc":     { "type": "string" }
      }
    },

    "agentHelpers": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": true,
        "required": ["verb", "what"],
        "properties": {
          "verb": { "type": "string", "minLength": 1 },
          "what": { "type": "string", "minLength": 1 }
        }
      }
    },

    "harvestableUnits": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "$comment": { "type": "string" },
        "patterns": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": ["name"],
            "properties": {
              "name":       { "type": "string", "minLength": 1 },
              "doc":        { "type": "string" },
              "convention": { "type": "string" }
            }
          }
        },
        "subsystems": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": ["name"],
            "properties": {
              "name":  { "type": "string", "minLength": 1 },
              "doc":   { "type": "string" },
              "files": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        }
      }
    },

    "readingOrders": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "minItems": 1,
        "items": { "type": "string", "minLength": 1 }
      },
      "description": "Per-audience reading orders. Keys are audience names (agent / harvester / operator / newcomer / etc.); values are ordered file lists."
    },

    "honestVerdict": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "$comment":       { "type": "string" },
        "aggregateScore": { "type": "string" },
        "topGap": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "aspect":  { "type": "string" },
            "score":   { "type": "string" },
            "reason":  { "type": "string" },
            "tracked": { "type": "string" }
          }
        },
        "pathTo10":    { "type": "string" },
        "perAudience": { "type": "string" }
      }
    }
  },

  "$defs": {
    "gate": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "what"],
      "properties": {
        "id":       { "type": "string", "minLength": 1 },
        "what":     { "type": "string", "minLength": 1 },
        "fixHint":  { "type": "string" }
      }
    }
  }
}
