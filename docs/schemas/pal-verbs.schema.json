{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://palllm.dev/schemas/pal-verbs-v1.schema.json",
  "title": "PalLLM pal.ps1 verb manifest",
  "type": "object",
  "required": ["schemaVersion", "lastAudited", "runner", "groups"],
  "additionalProperties": true,
  "properties": {
    "$schema": { "type": "string" },
    "$comment": { "type": "string" },
    "schemaVersion": { "const": 1 },
    "lastAudited": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "runner": {
      "type": "object",
      "required": ["shell"],
      "additionalProperties": { "type": "string" },
      "properties": {
        "shell": { "type": "string", "minLength": 1 },
        "windows": { "type": "string" },
        "alias": { "type": "string" }
      }
    },
    "groups": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["title", "tagline", "verbs"],
        "additionalProperties": false,
        "properties": {
          "title": { "type": "string", "minLength": 1 },
          "tagline": { "type": "string", "minLength": 1 },
          "verbs": {
            "type": "array",
            "minItems": 1,
            "items": { "$ref": "#/$defs/verb" }
          }
        }
      }
    },
    "examples": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "$comment": { "type": "string" },
        "lines": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["command", "what"],
            "additionalProperties": false,
            "properties": {
              "command": { "type": "string", "minLength": 1 },
              "what": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "verb": {
      "type": "object",
      "required": ["verb", "summary"],
      "additionalProperties": false,
      "properties": {
        "verb": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "summary": { "type": "string", "minLength": 1 },
        "script": { "type": "string", "minLength": 1 },
        "scripts": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "command": { "type": "string", "minLength": 1 }
      },
      "oneOf": [
        { "required": ["script"] },
        { "required": ["scripts"] },
        { "required": ["command"] },
        {
          "not": {
            "anyOf": [
              { "required": ["script"] },
              { "required": ["scripts"] },
              { "required": ["command"] }
            ]
          }
        }
      ]
    }
  }
}
