{
  "// Comment": "VS Code tasks for PalLLM. All tasks delegate to pal.ps1 (the verb-driven task runner) so the IDE shortcuts and the command-line shortcuts stay in sync.",
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build (Release)",
      "type": "process",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy", "Bypass",
        "-File", "${workspaceFolder}/pal.ps1",
        "build"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "silent",
        "clear": true
      },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "build (Debug)",
      "type": "process",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/PalLLM.sln",
        "--configuration", "Debug",
        "--nologo"
      ],
      "group": "build",
      "problemMatcher": "$msCompile"
    },
    {
      "label": "test",
      "type": "process",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy", "Bypass",
        "-File", "${workspaceFolder}/pal.ps1",
        "test"
      ],
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "presentation": { "reveal": "always", "clear": true },
      "problemMatcher": []
    },
    {
      "label": "audit (full)",
      "type": "process",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy", "Bypass",
        "-File", "${workspaceFolder}/pal.ps1",
        "audit"
      ],
      "presentation": { "reveal": "always", "clear": true },
      "problemMatcher": []
    },
    {
      "label": "audit (fast - no rebuild / tests)",
      "type": "process",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy", "Bypass",
        "-File", "${workspaceFolder}/pal.ps1",
        "fast-audit"
      ],
      "presentation": { "reveal": "always", "clear": true },
      "problemMatcher": []
    },
    {
      "label": "play (boot sidecar + open dashboard)",
      "type": "process",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy", "Bypass",
        "-File", "${workspaceFolder}/pal.ps1",
        "play"
      ],
      "presentation": { "reveal": "always", "clear": true },
      "problemMatcher": []
    },
    {
      "label": "onboard (first-time setup)",
      "type": "process",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy", "Bypass",
        "-File", "${workspaceFolder}/pal.ps1",
        "onboard"
      ],
      "presentation": { "reveal": "always", "clear": true },
      "problemMatcher": []
    },
    {
      "label": "regenerate OpenAPI snapshot",
      "type": "process",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy", "Bypass",
        "-File", "${workspaceFolder}/pal.ps1",
        "openapi"
      ],
      "presentation": { "reveal": "always", "clear": true },
      "problemMatcher": []
    },
    {
      "label": "doctor",
      "type": "process",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy", "Bypass",
        "-File", "${workspaceFolder}/pal.ps1",
        "doctor"
      ],
      "presentation": { "reveal": "always", "clear": true },
      "problemMatcher": []
    },
    {
      "label": "status",
      "type": "process",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy", "Bypass",
        "-File", "${workspaceFolder}/pal.ps1",
        "status"
      ],
      "presentation": { "reveal": "always", "clear": true },
      "problemMatcher": []
    }
  ]
}
